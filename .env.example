# Gemini API key used by the `/api/generate` serverless function.
# For local development, set either `GEMINI_API_KEY` or `VITE_GEMINI_API_KEY`.
# Prefer `GEMINI_API_KEY` for server-side use so the secret is not exposed to the client bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
